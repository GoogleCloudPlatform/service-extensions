# Multi-stage build for Cloud Run deployment.
# Builds the Go callout binary from source.

FROM golang:1.23-bookworm AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /callout ./extproc/cmd/example/

FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y ca-certificates && rm -rf /var/lib/apt/lists/*

WORKDIR /root/
COPY --from=builder /callout .
COPY extproc/ssl_creds ./extproc/ssl_creds

EXPOSE 443 8080 80

CMD ["./callout"]
